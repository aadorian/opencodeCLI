{
  "$schema": "https://json.schemastore.org/github-ruleset.json",
  "name": "Protect master",
  "target": "branch",
  "enforcement": "disabled",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/master"],
      "exclude": []
    }
  },
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true,
        "allowed_merge_methods": ["squash"]
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": true,
        "required_status_checks": [
          { "context": "Validate manifest" },
          { "context": "Extension tests (ubuntu-latest)" },
          { "context": "Extension tests (macos-latest)" },
          { "context": "Package VSIX" },
          { "context": "Conventional PR title" },
          { "context": "Conventional commits" },
          { "context": "Branch naming convention" }
        ]
      }
    },
    {
      "type": "required_linear_history"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "deletion"
    }
  ]
}
