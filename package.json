  "main": "./extension.js",
  "scripts": {
    "run": "node scripts/run-extension.js",
    "test": "vscode-test",
    "validate": "node scripts/validate-manifest.js",
    "screenshots": "node scripts/render-screenshots.js",
    "wiki": "node scripts/sync-wiki.js",
    "wiki:push": "node scripts/sync-wiki.js --push",
    "wiki:init": "node scripts/init-wiki-browser.js",
    "wiki:publish": "node scripts/wiki-publish.js",
    "wiki:verify": "node scripts/verify-wiki.js",
    "discussions:sync": "node scripts/sync-discussions.js",
    "vscode:prepublish": "node -e \"console.log('opencode-walkthrough: ready')\"",
    "publish": "npx @vscode/vsce package --no-dependencies"
  },
  "contributes": {
    "configuration": {
      "title": "OpenCode",
      "order": 0,
      "properties": {
        "opencode.configPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the OpenCode config file. Maps to `OPENCODE_CONFIG`"
        },
        "opencode.configDir": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the OpenCode config directory. Maps to `OPENCODE_CONFIG_DIR`"
        },
        "opencode.tuiConfigPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the TUI config file. Maps to `OPENCODE_TUI_CONFIG`"
        },
        "opencode.autoShare": {
          "type": "boolean",
          "markdownDescription": "Automatically share sessions. Maps to `OPENCODE_AUTO_SHARE`"
        },
        "opencode.modelsUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Custom URL for fetching models configuration. Maps to `OPENCODE_MODELS_URL`"
        },
        "opencode.serverPassword": {
          "type": "string",
          "default": "",
          "markdownDescription": "Password for HTTP basic auth on `serve`/`web`. Maps to `OPENCODE_SERVER_PASSWORD`"
        },
        "opencode.serverUsername": {
          "type": "string",
          "default": "",
          "markdownDescription": "Username for HTTP basic auth. Maps to `OPENCODE_SERVER_USERNAME`. Leave empty to use the CLI default (`opencode`)."
        },
        "opencode.logLevel": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ],
          "markdownDescription": "Log level for the OpenCode CLI. Maps to `--log-level` flag"
        },
        "opencode.disableAutoUpdate": {
          "type": "boolean",
          "markdownDescription": "Disable automatic update checks. Maps to `OPENCODE_DISABLE_AUTOUPDATE`"
        },
        "opencode.disablePrune": {
          "type": "boolean",
          "markdownDescription": "Disable pruning of old data. Maps to `OPENCODE_DISABLE_PRUNE`"
        },
        "opencode.disableTerminalTitle": {
          "type": "boolean",
          "markdownDescription": "Disable automatic terminal title updates. Maps to `OPENCODE_DISABLE_TERMINAL_TITLE`"
        },
        "opencode.disableDefaultPlugins": {
          "type": "boolean",
          "markdownDescription": "Disable default plugins. Maps to `OPENCODE_DISABLE_DEFAULT_PLUGINS`"
        },
        "opencode.disableLspDownload": {
          "type": "boolean",
          "markdownDescription": "Disable automatic LSP server downloads. Maps to `OPENCODE_DISABLE_LSP_DOWNLOAD`"
        },
        "opencode.disableAutoCompact": {
          "type": "boolean",
          "markdownDescription": "Disable automatic context compaction. Maps to `OPENCODE_DISABLE_AUTOCOMPACT`"
        },
        "opencode.disableClaudeCode": {
          "type": "boolean",
          "markdownDescription": "Disable reading from `.claude` (prompt + skills). Maps to `OPENCODE_DISABLE_CLAUDE_CODE`"
        },
        "opencode.disableModelsFetch": {
          "type": "boolean",
          "markdownDescription": "Disable fetching models from remote sources. Maps to `OPENCODE_DISABLE_MODELS_FETCH`"
        },
        "opencode.disableMouse": {
          "type": "boolean",
          "markdownDescription": "Disable mouse capture in the TUI. Maps to `OPENCODE_DISABLE_MOUSE`"
        },
        "opencode.experimental": {
          "type": "boolean",
          "markdownDescription": "Enable all experimental features. Maps to `OPENCODE_EXPERIMENTAL`"
        },
        "opencode.experimental.planMode": {
          "type": "boolean",
          "markdownDescription": "Enable experimental plan mode. Maps to `OPENCODE_EXPERIMENTAL_PLAN_MODE`"
        },
        "opencode.experimental.backgroundSubagents": {
          "type": "boolean",
          "markdownDescription": "Enable background subagent tasks. Maps to `OPENCODE_EXPERIMENTAL_BACKGROUND_SUBAGENTS`"
        },
        "opencode.experimental.nativeLlm": {
          "type": "boolean",
          "markdownDescription": "Enable native LLM request path. Maps to `OPENCODE_EXPERIMENTAL_NATIVE_LLM`"
        },
        "opencode.experimental.scout": {
          "type": "boolean",
          "markdownDescription": "Enable Scout subagent. Maps to `OPENCODE_EXPERIMENTAL_SCOUT`"
        },
        "opencode.experimental.workspaces": {
          "type": "boolean",
          "markdownDescription": "Enable workspace support. Maps to `OPENCODE_EXPERIMENTAL_WORKSPACES`"
        },
        "opencode.harness.maxRounds": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 100,
          "markdownDescription": "Maximum agent loop rounds per user turn before stopping."
        },
        "opencode.harness.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:4096",
          "markdownDescription": "Local URL for `opencode serve` when using the agent harness."
        },
        "opencode.harness.autoStartServer": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically start `opencode serve` when running the agent harness."
        },
        "opencode.harness.toolConfirmation": {
          "type": "string",
          "default": "smart",
          "enum": [
            "always",
            "smart",
            "never"
          ],
          "markdownDescription": "When to confirm destructive tool calls from the agent harness."
        },
        "opencode.harness.customInstructions": {
          "type": "string",
          "default": "",
          "markdownDescription": "Custom instructions injected into every harness-initiated session."
        },
        "opencode.harness.context.includeWorkspace": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Include workspace folder paths in harness context."
        },
        "opencode.harness.context.includeOpenEditors": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Include open editor tabs in harness context."
        },
        "opencode.harness.context.includeActiveFile": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Include active file metadata in harness context."
        },
        "opencode.harness.context.includeSelection": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Include active editor selection in harness context."
        },
        "opencode.harness.context.includeDiagnostics": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Include workspace diagnostics in harness context."
        },
        "opencode.harness.context.includeGit": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Include git branch and dirty files in harness context."
        },
        "opencode.harness.context.includeFileContents": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Include full active file contents in harness context (privacy-sensitive)."
        },
        "opencode.enableExa": {
          "type": "boolean",
          "markdownDescription": "Enable Exa web search tools. Maps to `OPENCODE_ENABLE_EXA`"
        }
      }
    },
