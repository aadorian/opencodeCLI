{
  "name": "opencode-walkthrough",
  "displayName": "OpenCode Walkthrough",
  "version": "0.0.6",
  "publisher": "AlejandroAdorjan",
  "author": {
    "name": "Alejandro Adorjan",
    "email": "aadorjan@users.noreply.github.com",
    "url": "https://github.com/aadorian"
  },
  "description": "Comprehensive VS Code integration for OpenCode — walkthroughs, tree views, CLI commands, IntelliSense, and keyboard shortcuts for AI-assisted software engineering",
  "keywords": [
    "opencode",
    "ai",
    "cli",
    "coding-agent",
    "llm",
    "mcp",
    "walkthrough",
    "getting-started",
    "commands",
    "terminal",
    "productivity",
    "snippets",
    "intellisense"
  ],
  "icon": "media/opencode-icon.png",
  "pricing": "Free",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://opencode.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/aadorian/opencodeCLI.git"
  },
  "bugs": {
    "url": "https://github.com/aadorian/opencodeCLI/issues",
    "email": "aadorjan@users.noreply.github.com"
  },
  "qna": "marketplace",
  "sponsor": {
    "url": "https://github.com/sponsors/aadorian"
  },
  "markdown": "github",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "preview": true,
  "engines": {
    "vscode": "^1.74.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Terminal commands require a trusted workspace"
    },
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "CLI commands require a local filesystem"
    }
  },
  "categories": [
    "Education",
    "Other"
  ],
  "activationEvents": [
    "onCommand:opencode-walkthrough.showWalkthrough",
    "onCommand:opencode-walkthrough.install",
    "onCommand:opencode-walkthrough.runInline",
    "onCommand:opencode-walkthrough.runInteractive",
    "onWalkthrough:opencode.gettingStarted",
    "onView:opencode-walkthrough.overview",
    "onCommand:opencode-walkthrough.showActions",
    "onCommand:opencode-walkthrough.showCliHelp",
    "onCommand:opencode-walkthrough.createAgent",
    "onCommand:opencode-walkthrough.listAgents",
    "onView:opencode-walkthrough.mcp",
    "onCommand:opencode-walkthrough.addMcp",
    "onCommand:opencode-walkthrough.listMcp",
    "onCommand:opencode-walkthrough.authLogin",
    "onCommand:opencode-walkthrough.authList",
    "onCommand:opencode-walkthrough.listModels",
    "onCommand:opencode-walkthrough.sessionList",
    "onCommand:opencode-walkthrough.stats",
    "onCommand:opencode-walkthrough.upgrade",
    "onCommand:opencode-walkthrough.serve",
    "onCommand:opencode-walkthrough.web",
    "onCommand:opencode-walkthrough.runOnProject",
    "onCommand:opencode-walkthrough.showTips",
    "onCommand:opencode-walkthrough.showAgents",
    "onCommand:opencode-walkthrough.showModels",
    "onCommand:opencode-walkthrough.refreshAgents",
    "onCommand:opencode-walkthrough.refreshMcp",
    "onCommand:opencode-walkthrough.refreshSessions",
    "onCommand:opencode-walkthrough.refreshModels",
    "onView:opencode-walkthrough.agents",
    "onView:opencode-walkthrough.models",
    "onView:opencode-walkthrough.sessions",
    "onView:opencode-walkthrough.agent",
    "onCommand:opencode-walkthrough.startAgent",
    "onCommand:opencode-walkthrough.cancelAgent",
    "onCommand:opencode-walkthrough.openAgentPanel",
    "onCommand:opencode-walkthrough.openAgentTab",
    "onCommand:opencode-walkthrough.resumeSession",
    "onCommand:opencode-walkthrough.version",
    "onCommand:opencode-walkthrough.checkHealth",
    "onCommand:opencode-walkthrough.authLogout",
    "onCommand:opencode-walkthrough.mcpRemove",
    "onCommand:opencode-walkthrough.uninstall"
