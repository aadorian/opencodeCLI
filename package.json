{
  "name": "opencode-walkthrough",
  "displayName": "OpenCode Walkthrough",
  "description": "A walkthrough for how to execute OpenCode commands in your terminal",
  "version": "0.0.1",
  "publisher": "aadorian",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "media/opencode-icon.png",
  "pricing": "Free",
  "keywords": [
    "opencode",
    "walkthrough",
    "getting-started",
    "ai",
    "cli",
    "help",
    "commands"
  ],
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aadorian/opencodeCLI.git"
  },
  "bugs": {
    "url": "https://github.com/aadorian/opencodeCLI/issues"
  },
  "homepage": "https://opencode.ai",
  "markdown": "github",
  "qna": "marketplace",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Education"
  ],
  "configuration": {
    "title": "OpenCode",
    "properties": {
      "opencode.configPath": {
        "type": "string",
        "default": "",
        "markdownDescription": "Path to the OpenCode config file. Maps to `OPENCODE_CONFIG`"
      },
      "opencode.configDir": {
        "type": "string",
        "default": "",
        "markdownDescription": "Path to the OpenCode config directory. Maps to `OPENCODE_CONFIG_DIR`"
      },
      "opencode.tuiConfigPath": {
        "type": "string",
        "default": "",
        "markdownDescription": "Path to the TUI config file. Maps to `OPENCODE_TUI_CONFIG`"
      },
      "opencode.autoShare": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Automatically share sessions. Maps to `OPENCODE_AUTO_SHARE`"
      },
      "opencode.modelsUrl": {
        "type": "string",
        "default": "",
        "markdownDescription": "Custom URL for fetching models configuration. Maps to `OPENCODE_MODELS_URL`"
      },
      "opencode.serverPassword": {
        "type": "string",
        "default": "",
        "markdownDescription": "Password for HTTP basic auth on `serve`/`web`. Maps to `OPENCODE_SERVER_PASSWORD`"
      },
      "opencode.serverUsername": {
        "type": "string",
        "default": "opencode",
        "markdownDescription": "Username for HTTP basic auth. Maps to `OPENCODE_SERVER_USERNAME`"
      },
      "opencode.logLevel": {
        "type": "string",
        "default": "",
        "enum": ["", "DEBUG", "INFO", "WARN", "ERROR"],
        "markdownDescription": "Log level for the OpenCode CLI. Maps to `--log-level` flag"
      },
      "opencode.disableAutoUpdate": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable automatic update checks. Maps to `OPENCODE_DISABLE_AUTOUPDATE`"
      },
      "opencode.disablePrune": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable pruning of old data. Maps to `OPENCODE_DISABLE_PRUNE`"
      },
      "opencode.disableTerminalTitle": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable automatic terminal title updates. Maps to `OPENCODE_DISABLE_TERMINAL_TITLE`"
      },
      "opencode.disableDefaultPlugins": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable default plugins. Maps to `OPENCODE_DISABLE_DEFAULT_PLUGINS`"
      },
      "opencode.disableLspDownload": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable automatic LSP server downloads. Maps to `OPENCODE_DISABLE_LSP_DOWNLOAD`"
      },
      "opencode.disableAutoCompact": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable automatic context compaction. Maps to `OPENCODE_DISABLE_AUTOCOMPACT`"
      },
      "opencode.disableClaudeCode": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable reading from `.claude` (prompt + skills). Maps to `OPENCODE_DISABLE_CLAUDE_CODE`"
      },
      "opencode.disableModelsFetch": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable fetching models from remote sources. Maps to `OPENCODE_DISABLE_MODELS_FETCH`"
      },
      "opencode.disableMouse": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Disable mouse capture in the TUI. Maps to `OPENCODE_DISABLE_MOUSE`"
      },
      "opcode.enableExa": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Enable Exa web search tools. Maps to `OPENCODE_ENABLE_EXA`"
      },
      "opencode.experimental": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Enable all experimental features. Maps to `OPENCODE_EXPERIMENTAL`"
      },
      "opencode.experimental.planMode": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Enable experimental plan mode. Maps to `OPENCODE_EXPERIMENTAL_PLAN_MODE`"
      },
      "opencode.experimental.backgroundSubagents": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Enable background subagent tasks. Maps to `OPENCODE_EXPERIMENTAL_BACKGROUND_SUBAGENTS`"
      },
      "opencode.experimental.nativeLlm": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Enable native LLM request path. Maps to `OPENCODE_EXPERIMENTAL_NATIVE_LLM`"
      },
      "opencode.experimental.scout": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Enable Scout subagent. Maps to `OPENCODE_EXPERIMENTAL_SCOUT`"
      },
      "opencode.experimental.workspaces": {
        "type": "boolean",
        "default": null,
        "markdownDescription": "Enable workspace support. Maps to `OPENCODE_EXPERIMENTAL_WORKSPACES`"
      }
    }
  },
  "activationEvents": [
    "onCommand:opencode-walkthrough.showWalkthrough",
    "onCommand:opencode-walkthrough.install",
    "onCommand:opencode-walkthrough.runInline",
    "onCommand:opencode-walkthrough.runInteractive",
    "onWalkthrough:opencode.gettingStarted",
    "onView:opencode-walkthrough.overview",
    "onCommand:opencode-walkthrough.showActions",
    "onCommand:opencode-walkthrough.showCliHelp",
    "onCommand:opencode-walkthrough.createAgent",
    "onCommand:opencode-walkthrough.listAgents",
    "onView:opencode-walkthrough.mcp",
    "onView:opencode-walkthrough.help",
    "onCommand:opencode-walkthrough.addMcp",
    "onCommand:opencode-walkthrough.listMcp",
    "onCommand:opencode-walkthrough.authLogin",
    "onCommand:opencode-walkthrough.authList",
    "onCommand:opencode-walkthrough.listModels",
    "onCommand:opencode-walkthrough.sessionList",
    "onCommand:opencode-walkthrough.stats",
    "onCommand:opencode-walkthrough.upgrade",
    "onCommand:opencode-walkthrough.serve",
    "onCommand:opencode-walkthrough.web"
  ],
  "scripts": {
    "test": "vscode-test"
  },
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-walkthrough",
          "title": "OpenCode",
          "icon": "media/opencode-icon.png"
        }
      ],
      "panel": [
        {
          "id": "opencode-mcp",
          "title": "MCP Servers",
          "icon": "media/opencode-icon.png"
        }
      ]
    },
    "views": {
      "opencode-walkthrough": [
        {
          "type": "tree",
          "id": "opencode-walkthrough.overview",
          "name": "OpenCode"
        }
      ],
      "opencode-mcp": [
        {
          "type": "tree",
          "id": "opencode-walkthrough.mcp",
          "name": "MCP Servers"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode-walkthrough.showWalkthrough",
        "title": "OpenCode: Show Walkthrough",
        "icon": "$(book)"
      },
      {
        "command": "opencode-walkthrough.install",
        "title": "OpenCode: Install CLI",
        "icon": "$(cloud-download)"
      },
      {
        "command": "opencode-walkthrough.runInline",
        "title": "OpenCode: Run Inline Prompt",
        "icon": "$(play)"
      },
      {
        "command": "opencode-walkthrough.runInteractive",
        "title": "OpenCode: Start Interactive Session",
        "icon": "$(terminal)"
      },
      {
        "command": "opencode-walkthrough.createAgent",
        "title": "OpenCode: Create Agent",
        "icon": "$(robot)"
      },
      {
        "command": "opencode-walkthrough.listAgents",
        "title": "OpenCode: List Agents",
        "icon": "$(list-tree)"
      },
      {
        "command": "opencode-walkthrough.authLogin",
        "title": "OpenCode: Auth Login",
        "icon": "$(key)"
      },
      {
        "command": "opencode-walkthrough.authList",
        "title": "OpenCode: Auth List",
        "icon": "$(key)"
      },
      {
        "command": "opencode-walkthrough.addMcp",
        "title": "OpenCode: Add MCP Server",
        "icon": "$(plug)"
      },
      {
        "command": "opencode-walkthrough.listMcp",
        "title": "OpenCode: List MCP Servers",
        "icon": "$(list-tree)"
      },
      {
        "command": "opencode-walkthrough.listModels",
        "title": "OpenCode: List Models",
        "icon": "$(symbol-parameter)"
      },
      {
        "command": "opencode-walkthrough.sessionList",
        "title": "OpenCode: List Sessions",
        "icon": "$(list-tree)"
      },
      {
        "command": "opencode-walkthrough.stats",
        "title": "OpenCode: Stats",
        "icon": "$(graph)"
      },
      {
        "command": "opencode-walkthrough.serve",
        "title": "OpenCode: Start Server",
        "icon": "$(server)"
      },
      {
        "command": "opencode-walkthrough.web",
        "title": "OpenCode: Start Web Interface",
        "icon": "$(globe)"
      },
      {
        "command": "opencode-walkthrough.upgrade",
        "title": "OpenCode: Upgrade CLI",
        "icon": "$(arrow-up)"
      },
      {
        "command": "opencode-walkthrough.showActions",
        "title": "OpenCode: Show Actions"
      },
      {
        "command": "opencode-walkthrough.showCliHelp",
        "title": "OpenCode: CLI Help",
        "icon": "$(question)"
      }
    ],
    "viewsWelcome": [
      {
        "view": "opencode-walkthrough.overview",
        "contents": "OpenCode is a CLI for AI-assisted software engineering tasks.\n\n[Show Walkthrough](command:opencode-walkthrough.showWalkthrough)\n[Install CLI](command:opencode-walkthrough.install)\n[Run Inline Prompt](command:opencode-walkthrough.runInline)\n[Start Interactive Session](command:opencode-walkthrough.runInteractive)\n[Create Agent](command:opencode-walkthrough.createAgent)\n\n[CLI Help](command:opencode-walkthrough.showCliHelp)\n[Read Documentation](https://opencode.ai)"
      },
      {
        "view": "opencode-walkthrough.mcp",
        "contents": "Manage Model Context Protocol servers for OpenCode.\n\n[Add MCP Server](command:opencode-walkthrough.addMcp)\n[List MCP Servers](command:opencode-walkthrough.listMcp)\n\n[Read MCP Docs](https://opencode.ai/docs/mcp-servers/)"
      }
    ],
    "submenus": [
      {
        "id": "opencode-walkthrough.submenu",
        "label": "OpenCode"
      },
      {
        "id": "opencode-walkthrough.helpSubmenu",
        "label": "OpenCode CLI"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "opencode-walkthrough.showWalkthrough",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.install",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.runInline",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.runInteractive",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.createAgent",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.showCliHelp",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.stats",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.addMcp",
          "when": "view == opencode-walkthrough.mcp",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.listMcp",
          "when": "view == opencode-walkthrough.mcp",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "opencode-walkthrough.stats",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ],
      "menubar": [
        {
          "submenu": "opencode-walkthrough.helpSubmenu",
          "group": "9_help"
        }
      ],
      "opencode-walkthrough.helpSubmenu": [
        {
          "command": "opencode-walkthrough.showCliHelp"
        },
        {
          "submenu": "opencode-walkthrough.submenu",
          "group": "inline"
        },
        {
          "command": "opencode-walkthrough.runInline"
        },
        {
          "command": "opencode-walkthrough.runInteractive"
        },
        {
          "command": "opencode-walkthrough.createAgent"
        },
        {
          "command": "opencode-walkthrough.listAgents"
        },
        {
          "command": "opencode-walkthrough.authLogin"
        },
        {
          "command": "opencode-walkthrough.authList"
        },
        {
          "command": "opencode-walkthrough.addMcp"
        },
        {
          "command": "opencode-walkthrough.listMcp"
        },
        {
          "command": "opencode-walkthrough.listModels"
        },
        {
          "command": "opencode-walkthrough.sessionList"
        },
        {
          "command": "opencode-walkthrough.stats"
        },
        {
          "command": "opencode-walkthrough.serve"
        },
        {
          "command": "opencode-walkthrough.web"
        },
        {
          "command": "opencode-walkthrough.upgrade"
        }
      ],
      "explorer/context": [
        {
          "submenu": "opencode-walkthrough.submenu",
          "group": "navigation",
          "when": "explorerResourceIsFolder"
        }
      ],
      "opencode-walkthrough.submenu": [
        {
          "command": "opencode-walkthrough.runInline"
        },
        {
          "command": "opencode-walkthrough.runInteractive"
        },
        {
          "command": "opencode-walkthrough.createAgent"
        },
        {
          "command": "opencode-walkthrough.addMcp"
        }
      ]
    },
    "startEntries": [
      {
        "title": "Get Started with OpenCode",
        "description": "Learn how to run OpenCode commands in your terminal",
        "command": "opencode-walkthrough.showWalkthrough",
        "category": "folder"
      }
    ],
    "walkthroughs": [
      {
        "id": "opencode.gettingStarted",
        "title": "Get Started with OpenCode",
        "description": "Install the CLI, run prompts, and start interactive sessions for software engineering tasks",
  "icon": "media/opencode-icon.png",
        "steps": [
          {
            "id": "opencode.install",
            "title": "Install OpenCode",
            "description": "OpenCode is a CLI for software engineering tasks. Install it globally with npm, then confirm with `opencode --version`.\n[Install OpenCode](command:opencode-walkthrough.install)",
            "media": {
              "markdown": "walkthroughs/01-install.md"
            },
            "completionEvents": [
              "onCommand:opencode-walkthrough.install"
            ]
          },
          {
            "id": "opencode.runInline",
            "title": "Run a Prompt",
            "description": "Pass a prompt directly to OpenCode without interactive mode — generate code, save output to a file, or run one-off tasks.\n[Run Inline Prompt](command:opencode-walkthrough.runInline)",
            "media": {
              "markdown": "walkthroughs/02-run-inline.md"
            },
            "completionEvents": [
              "onCommand:opencode-walkthrough.runInline"
            ]
          },
          {
            "id": "opencode.runInteractive",
            "title": "Start Interactive Mode",
            "description": "Launch OpenCode without arguments to ask follow-ups, refine requests, and iterate on results.\n[Start Interactive Session](command:opencode-walkthrough.runInteractive)",
            "media": {
              "markdown": "walkthroughs/03-run-interactive.md"
            },
            "completionEvents": [
              "onCommand:opencode-walkthrough.runInteractive"
            ]
          },
          {
            "id": "opencode.createAgent",
            "title": "Create an Agent",
            "description": "Create a custom agent with specific instructions and permissions.\n[Create Agent](command:opencode-walkthrough.createAgent)",
            "media": {
              "markdown": "walkthroughs/04-create-agent.md"
            },
            "completionEvents": [
              "onCommand:opencode-walkthrough.createAgent"
            ]
          },
          {
            "id": "opencode.tips",
            "title": "Tips & Best Practices",
            "description": "Use VS Code's integrated terminal, write specific prompts, and iterate with follow-ups.\n[Open Terminal](command:workbench.action.terminal.toggleTerminal)\n[Read Documentation](https://opencode.ai)",
            "media": {
              "markdown": "walkthroughs/05-tips.md"
            },
            "completionEvents": [
              "onView:terminal",
              "onLink:https://opencode.ai"
            ]
          }
        ]
      }
    ]
  },
  "devDependencies": {
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "sharp": "^0.35.2"
  }
}
