{
  "name": "opencode-walkthrough",
  "displayName": "OpenCode Walkthrough",
  "description": "A walkthrough for how to execute OpenCode commands in your terminal",
  "version": "0.0.1",
  "publisher": "aadorian",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "media/opencode-icon.svg",
  "pricing": "Free",
  "keywords": [
    "opencode",
    "walkthrough",
    "getting-started",
    "ai",
    "cli"
  ],
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aadorian/opencodeCLI.git"
  },
  "bugs": {
    "url": "https://github.com/aadorian/opencodeCLI/issues"
  },
  "homepage": "https://opencode.ai",
  "markdown": "github",
  "qna": "marketplace",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Education"
  ],
  "activationEvents": [
    "onCommand:opencode-walkthrough.showWalkthrough",
    "onCommand:opencode-walkthrough.install",
    "onCommand:opencode-walkthrough.runInline",
    "onCommand:opencode-walkthrough.runInteractive",
    "onWalkthrough:opencode.gettingStarted",
    "onView:opencode-walkthrough.overview",
    "onCommand:opencode-walkthrough.showActions",
    "onCommand:opencode-walkthrough.createAgent",
    "onCommand:opencode-walkthrough.listAgents",
    "onView:opencode-walkthrough.mcp",
    "onCommand:opencode-walkthrough.addMcp",
    "onCommand:opencode-walkthrough.listMcp"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-walkthrough",
          "title": "OpenCode",
          "icon": "media/opencode-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "opencode-mcp",
          "title": "MCP Servers",
          "icon": "media/opencode-icon.svg"
        }
      ]
    },
    "views": {
      "opencode-walkthrough": [
        {
          "type": "tree",
          "id": "opencode-walkthrough.overview",
          "name": "OpenCode"
        }
      ],
      "opencode-mcp": [
        {
          "type": "tree",
          "id": "opencode-walkthrough.mcp",
          "name": "MCP Servers"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode-walkthrough.showWalkthrough",
        "title": "OpenCode: Show Walkthrough",
        "icon": "$(book)"
      },
      {
        "command": "opencode-walkthrough.install",
        "title": "OpenCode: Install CLI",
        "icon": "$(cloud-download)"
      },
      {
        "command": "opencode-walkthrough.runInline",
        "title": "OpenCode: Run Inline Prompt",
        "icon": "$(play)"
      },
      {
        "command": "opencode-walkthrough.runInteractive",
        "title": "OpenCode: Start Interactive Session",
        "icon": "$(terminal)"
      },
      {
        "command": "opencode-walkthrough.createAgent",
        "title": "OpenCode: Create Agent",
        "icon": "$(robot)"
      },
      {
        "command": "opencode-walkthrough.listAgents",
        "title": "OpenCode: List Agents",
        "icon": "$(list-tree)"
      },
      {
        "command": "opencode-walkthrough.addMcp",
        "title": "OpenCode: Add MCP Server",
        "icon": "$(plug)"
      },
      {
        "command": "opencode-walkthrough.listMcp",
        "title": "OpenCode: List MCP Servers",
        "icon": "$(list-tree)"
      },
      {
        "command": "opencode-walkthrough.showActions",
        "title": "OpenCode: Show Actions"
      }
    ],
    "viewsWelcome": [
      {
        "view": "opencode-walkthrough.overview",
        "contents": "OpenCode is a CLI for AI-assisted software engineering tasks.\n\n[Show Walkthrough](command:opencode-walkthrough.showWalkthrough)\n[Install CLI](command:opencode-walkthrough.install)\n[Run Inline Prompt](command:opencode-walkthrough.runInline)\n[Start Interactive Session](command:opencode-walkthrough.runInteractive)\n[Create Agent](command:opencode-walkthrough.createAgent)\n\n[Read Documentation](https://opencode.ai)"
      },
      {
        "view": "opencode-walkthrough.mcp",
        "contents": "Manage Model Context Protocol servers for OpenCode.\n\n[Add MCP Server](command:opencode-walkthrough.addMcp)\n[List MCP Servers](command:opencode-walkthrough.listMcp)\n\n[Read MCP Docs](https://opencode.ai/docs/mcp-servers/)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "opencode-walkthrough.showWalkthrough",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.install",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.runInline",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.runInteractive",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.createAgent",
          "when": "view == opencode-walkthrough.overview",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.addMcp",
          "when": "view == opencode-walkthrough.mcp",
          "group": "navigation"
        },
        {
          "command": "opencode-walkthrough.listMcp",
          "when": "view == opencode-walkthrough.mcp",
          "group": "navigation"
        }
      ]
    },
    "startEntries": [
      {
        "title": "Get Started with OpenCode",
        "description": "Learn how to run OpenCode commands in your terminal",
        "command": "opencode-walkthrough.showWalkthrough",
        "category": "folder"
      }
    ],
    "walkthroughs": [
      {
        "id": "opencode.gettingStarted",
        "title": "Get Started with OpenCode",
        "description": "Install the CLI, run prompts, and start interactive sessions for software engineering tasks",
        "icon": "media/opencode-icon.svg",
        "steps": [
          {
            "id": "opencode.install",
            "title": "Install OpenCode",
            "description": "OpenCode is a CLI for software engineering tasks. Install it globally with npm, then confirm with `opencode --version`.\n[Install OpenCode](command:opencode-walkthrough.install)",
            "media": {
              "markdown": "walkthroughs/01-install.md"
            },
            "completionEvents": [
              "onCommand:opencode-walkthrough.install"
            ]
          },
          {
            "id": "opencode.runInline",
            "title": "Run a Prompt",
            "description": "Pass a prompt directly to OpenCode without interactive mode — generate code, save output to a file, or run one-off tasks.\n[Run Inline Prompt](command:opencode-walkthrough.runInline)",
            "media": {
              "markdown": "walkthroughs/02-run-inline.md"
            },
            "completionEvents": [
              "onCommand:opencode-walkthrough.runInline"
            ]
          },
          {
            "id": "opencode.runInteractive",
            "title": "Start Interactive Mode",
            "description": "Launch OpenCode without arguments to ask follow-ups, refine requests, and iterate on results.\n[Start Interactive Session](command:opencode-walkthrough.runInteractive)",
            "media": {
              "markdown": "walkthroughs/03-run-interactive.md"
            },
            "completionEvents": [
              "onCommand:opencode-walkthrough.runInteractive"
            ]
          },
          {
            "id": "opencode.createAgent",
            "title": "Create an Agent",
            "description": "Create a custom agent with specific instructions and permissions.\n[Create Agent](command:opencode-walkthrough.createAgent)",
            "media": {
              "markdown": "walkthroughs/04-create-agent.md"
            },
            "completionEvents": [
              "onCommand:opencode-walkthrough.createAgent"
            ]
          },
          {
            "id": "opencode.tips",
            "title": "Tips & Best Practices",
            "description": "Use VS Code's integrated terminal, write specific prompts, and iterate with follow-ups.\n[Open Terminal](command:workbench.action.terminal.toggleTerminal)\n[Read Documentation](https://opencode.ai)",
            "media": {
              "markdown": "walkthroughs/05-tips.md"
            },
            "completionEvents": [
              "onView:terminal",
              "onLink:https://opencode.ai"
            ]
          }
        ]
      }
    ]
  }
}
