    "viewsWelcome": [
      {
        "view": "opencode-walkthrough.overview",
        "contents": "OpenCode is a CLI for AI-assisted software engineering tasks.\n\n[Show Walkthrough](command:opencode-walkthrough.showWalkthrough)\n[Install CLI](command:opencode-walkthrough.install)\n[Check Version](command:opencode-walkthrough.version)\n[Check Health](command:opencode-walkthrough.checkHealth)\n[Run Inline Prompt](command:opencode-walkthrough.runInline)\n[Run on Project Files](command:opencode-walkthrough.runOnProject)\n[Start Interactive Session](command:opencode-walkthrough.runInteractive)\n[Start Agent Session](command:opencode-walkthrough.startAgent)\n[Create Agent](command:opencode-walkthrough.createAgent)\n\n[Auth Login](command:opencode-walkthrough.authLogin)\n[Auth Logout](command:opencode-walkthrough.authLogout)\n\n[Agents Overview](command:opencode-walkthrough.showAgents)\n[Models Overview](command:opencode-walkthrough.showModels)\n\n[CLI Help](command:opencode-walkthrough.showCliHelp)\n[Tips & Tricks](command:opencode-walkthrough.showTips)\n[Read Documentation](https://opencode.ai)\n"
      },
      {
        "view": "opencode-walkthrough.agents",
        "contents": "No agents found. Agents are custom configurations with specific prompts and permissions.\n\n[Create Agent](command:opencode-walkthrough.createAgent)\n[Agents Overview](command:opencode-walkthrough.showAgents)"
      },
      {
        "view": "opencode-walkthrough.models",
        "contents": "No models found. Configure a provider and authenticate first.\n\n[Auth Login](command:opencode-walkthrough.authLogin)\n[Models Overview](command:opencode-walkthrough.showModels)"
      },
      {
        "view": "opencode-walkthrough.mcp",
        "contents": "Manage Model Context Protocol servers for OpenCode.\n\n[Add MCP Server](command:opencode-walkthrough.addMcp)\n[List MCP Servers](command:opencode-walkthrough.listMcp)\n[Remove MCP Server](command:opencode-walkthrough.mcpRemove)\n\n[Read MCP Docs](https://opencode.ai/docs/mcp-servers/)"
      },
      {
        "view": "opencode-walkthrough.sessions",
        "contents": "No sessions yet. Run a prompt to create one.\n\n[Run Inline Prompt](command:opencode-walkthrough.runInline)\n[Start Agent Session](command:opencode-walkthrough.startAgent)\n[Start Interactive Session](command:opencode-walkthrough.runInteractive)"
      },
      {
        "view": "opencode-walkthrough.agent",
        "contents": "Chat with OpenCode from VS Code using the agent harness.\n\n[Start Agent Session](command:opencode-walkthrough.startAgent)\n[Open TUI](command:opencode-walkthrough.runInteractive)"
      }
    ],
