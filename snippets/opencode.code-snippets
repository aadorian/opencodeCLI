    "description": "Log in to a specific provider"
  },
  "OpenCode - Auth list": {
    "scope": "shellscript,markdown",
    "prefix": "oc-auth-list",
    "body": "opencode auth ls",
    "description": "List authenticated providers"
  },
  "OpenCode - Auth logout": {
    "scope": "shellscript,markdown",
    "prefix": "oc-auth-logout",
    "body": "opencode auth logout",
