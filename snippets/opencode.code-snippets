{
  "OpenCode - TUI": {
    "scope": "shellscript,markdown",
    "prefix": "oc",
    "body": "opencode",
    "description": "Start the OpenCode TUI"
  },
  "OpenCode - TUI with project": {
    "scope": "shellscript,markdown",
    "prefix": "oc-project",
    "body": "opencode ${1:project-path}",
    "description": "Start OpenCode TUI in a specific project"
  },
  "OpenCode - Continue session": {
    "scope": "shellscript,markdown",
    "prefix": "oc-continue",
    "body": "opencode --continue ${1:--session ${2:session-id}}",
    "description": "Continue the last session"
  },
  "OpenCode - TUI with model": {
    "scope": "shellscript,markdown",
    "prefix": "oc-model",
    "body": "opencode --model ${1:provider/model}",
    "description": "Start TUI with a specific model"
  },
  "OpenCode - TUI with agent": {
    "scope": "shellscript,markdown",
    "prefix": "oc-agent",
    "body": "opencode --agent ${1:agent-name}",
    "description": "Start TUI with a specific agent"
  },
  "OpenCode - Run prompt": {
    "scope": "shellscript,markdown",
    "prefix": "ocr",
    "body": "opencode run \"${1:your prompt}\"",
    "description": "Run a one-shot prompt"
  },
  "OpenCode - Run with files": {
    "scope": "shellscript,markdown",
    "prefix": "ocr-file",
    "body": "opencode run --file ${1:path/to/file} \"${2:prompt}\"",
    "description": "Run a prompt with attached files"
  },
  "OpenCode - Run with model": {
    "scope": "shellscript,markdown",
    "prefix": "ocr-model",
    "body": "opencode run --model ${1:provider/model} \"${2:prompt}\"",
    "description": "Run a prompt with a specific model"
  },
  "OpenCode - Run and share": {
    "scope": "shellscript,markdown",
    "prefix": "ocr-share",
    "body": "opencode run --share \"${1:prompt}\"",
    "description": "Run a prompt and share the session"
  },
  "OpenCode - Run with agent": {
    "scope": "shellscript,markdown",
    "prefix": "ocr-agent",
    "body": "opencode run --agent ${1:agent-name} \"${2:prompt}\"",
    "description": "Run a prompt with a specific agent"
  },
  "OpenCode - Run attach to server": {
    "scope": "shellscript,markdown",
    "prefix": "ocr-attach",
    "body": "opencode run --attach http://localhost:${1:4096} \"${2:prompt}\"",
    "description": "Run a prompt attached to a running server"
  },
  "OpenCode - Run with JSON output": {
    "scope": "shellscript,markdown",
    "prefix": "ocr-json",
    "body": "opencode run --format json \"${1:prompt}\"",
    "description": "Run a prompt and output raw JSON events"
  },
  "OpenCode - Agent create": {
    "scope": "shellscript,markdown",
    "prefix": "oc-agent-create",
    "body": "opencode agent create",
    "description": "Create a new agent interactively"
  },
  "OpenCode - Agent create (non-interactive)": {
    "scope": "shellscript,markdown",
    "prefix": "oc-agent-create-ni",
    "body": "opencode agent create --path ${1:./path} --description \"${2:agent description}\" --mode ${3|all,primary,subagent|} --permissions \"${4:bash,read,edit,glob,grep}\"",
    "description": "Create an agent non-interactively"
  },
  "OpenCode - Agent list": {
    "scope": "shellscript,markdown",
    "prefix": "oc-agent-list",
    "body": "opencode agent list",
    "description": "List all available agents"
  },
  "OpenCode - Auth login": {
    "scope": "shellscript,markdown",
    "prefix": "oc-auth-login",
